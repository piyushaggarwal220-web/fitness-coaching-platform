{%- if section.settings.enabled -%}
  {%- assign show_coach = true -%}
  {%- if section.settings.homepage_only and request.page_type != 'index' -%}
    {%- assign show_coach = false -%}
  {%- endif -%}

  {%- if show_coach -%}
    <aside
      class="lurvox-coach-login"
      aria-label="Coach account access"
    >
      <div class="lurvox-coach-login__inner">
        <a class="lurvox-coach-login__link" href="{{ section.settings.login_url }}">
          {{ section.settings.label }}
        </a>
      </div>
    </aside>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .lurvox-coach-login {
    width: 100%;
    color: rgba(255, 255, 255, 0.55);
    background: #0b0b0b;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .lurvox-coach-login__inner {
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px max(20px, env(safe-area-inset-right)) 22px max(20px, env(safe-area-inset-left));
    box-sizing: border-box;
  }

  .lurvox-coach-login__link {
    color: rgba(255, 255, 255, 0.52);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.3;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 160ms ease, border-color 160ms ease;
    -webkit-tap-highlight-color: transparent;
  }

  .lurvox-coach-login__link:hover {
    color: rgba(255, 255, 255, 0.88);
    border-bottom-color: rgba(255, 255, 255, 0.35);
  }

  .lurvox-coach-login__link:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
  }

  @media screen and (max-width: 749px) {
    .lurvox-coach-login__inner {
      padding-block: 16px 20px;
    }

    .lurvox-coach-login__link {
      font-size: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lurvox-coach-login__link {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Coach login link",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show coach login",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "homepage_only",
      "label": "Show on homepage only",
      "default": false
    },
    {
      "type": "text",
      "id": "label",
      "label": "Link label",
      "default": "Coach sign in"
    },
    {
      "type": "text",
      "id": "login_url",
      "label": "Coach login URL",
      "default": "https://app.lurvox.in/coach/login"
    }
  ]
}
{% endschema %}
