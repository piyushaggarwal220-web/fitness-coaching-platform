# Cron (Vercel Cron sends Authorization: Bearer $CRON_SECRET)
CRON_SECRET=

# AiSensy WhatsApp (WHATSAPP_API_* deprecated — unused)
AISENSY_API_KEY=
AISENSY_CAMPAIGN_CHECKIN_DUE=
AISENSY_CAMPAIGN_MISSED_CHECKIN=
AISENSY_CAMPAIGN_PLAN_READY=
AISENSY_CAMPAIGN_COACH_REPLIED=
AISENSY_CAMPAIGN_ACCOUNT_SETUP=
AISENSY_CAMPAIGN_ONBOARDING_REMINDER=

# Transactional email (server only)
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=

# Canonical app URL used in recovery/reminder links
NEXT_PUBLIC_APP_URL=

# Meta Conversions API (server only; pixel ID may match the public browser pixel)
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
META_CONVERSIONS_API_VERSION=v22.0

# Anthropic resilience (server only)
ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_MODEL=
ANTHROPIC_MAX_ATTEMPTS=3

# Meta Pixel (public browser-side ID)
NEXT_PUBLIC_META_PIXEL_ID=
